#!/usr/bin/stap
#
# IntP v1.1 -- SystemTap script + userspace helper
#
# Identical to v1 (stap-native software metrics + native LLC miss probes),
# plus mbw and llcocc fed from /tmp/intp-hw-data which the userspace
# helper rewrites once per second.
#
# The helper (intp-helper) MUST be running for mbw/llcocc to report
# non-zero values. If the helper is not running:
#   - /tmp/intp-hw-data is missing -> mbw=0 and llcocc=0 (graceful)
#   - this script keeps working otherwise
#
# Why a userspace helper:
#   On kernel >= 5.15, calling perf_event_create_kernel_counter() and
#   resctrl filp_open()/kernel_write() from stap embedded C in probe
#   context triggers "voluntary context switch within RCU read-side
#   critical section" and an unrecoverable RCU stall. v1.1 moves all
#   such calls to a separate process; this script only reads the
#   helper's output file from the procfs read probe (user-task context,
#   RCU-safe).
#
# Two probe-attach modes are supported via the @1 argument:
#   - @1 = <comm-pattern>   per-process mode (stress-ng workloads): probes
#                           are pinned to the workload's binary via
#                           process(@1).{begin,thread.begin,end,...} and
#                           perf events use .process(@1) for per-PID
#                           attribution. mpids[] is populated by the begin
#                           probes, and netfilter / scheduler filter on it.
#   - @1 = "@system"        system-wide mode (HiBench / dynamically-spawned
#                           workloads such as Spark Driver launched after
#                           stap attach, possibly inside a netns): no
#                           process(@1) probes are emitted, perf events
#                           attach host-wide, and netfilter / scheduler
#                           drop the mpids filter so all kernel events on
#                           the host count toward the metric. Matches the
#                           system-wide semantics V2 / V3 / V3.1 use for
#                           HiBench, fixing the structural PID-filter
#                           blindspot documented in METRICS-ALIGNMENT.md.
#                           The helper still receives a real comm pattern
#                           (e.g. "java") for its resctrl mon_group PID
#                           enrollment; only the stap side switches.
#
# Build/Usage:
#   1. cd variants/v1.1-stap-helper && make
#   2. sudo ./intp-helper <comm-pattern> &       # helper always uses comm
#   3. # per-process (stress-ng):
#      sudo stap -g -B CONFIG_MODVERSIONS=y intp-v1.1.stp <comm-pattern>
#      # system-wide (HiBench / Spark):
#      sudo stap -g -B CONFIG_MODVERSIONS=y intp-v1.1.stp '@system'
#   4. (after run) kill the helper
#
# Output columns (unchanged from v0/v1): time_ms netp nets blk mbw llcmr llcocc cpu

global interval = 1

# Physical NIC line rate in bytes/sec, used by print_netphy_report.
# Default is 1 GbE (125 MB/s); the orchestrator overrides via
# `stap -G nic_bytes_per_sec=$((INTP_NIC_SPEED_MBPS * 125000))` so the
# same script works for 1/10/25/40/100 GbE hosts without recompiling.
global nic_bytes_per_sec = 125000000

# Online CPU count, detected dynamically at module load via num_online_cpus().
# Used by print_cpu_report to normalise scheduler-tracked run_ns against the
# capacity window (window_ns × cores). Replaces the previous hardcoded
# `CPU_TOTAL_CORES = 48` so the same script works across 1-socket / multi-
# socket hosts and any core count.
function intp_num_online_cpus:long() %{ STAP_RETVALUE = num_online_cpus(); %}

probe begin
{
	CPU_TOTAL_CORES = intp_num_online_cpus()
	if (CPU_TOTAL_CORES < 1) CPU_TOTAL_CORES = 1
	printf("IntP v1.1 (stap + userspace helper) — detected %d online CPUs\n", CPU_TOTAL_CORES)
%( @1 == "@system" %?
	printf("Mode: SYSTEM-WIDE (no PID filter; matches V2/V3/V3.1 semantics)\n")
	/* Seed accounting state so every `nprocs > 0` gate opens immediately
	 * and so initial_time / runtime_procfs flow without waiting for a
	 * process(@1).begin we never installed. */
	initial_time = gettimeofday_ns()
	nprocs = 1
	started = 1
%:
	printf("Mode: PER-PROCESS — tracing processes named \"%s\"\n", @1)
%)
	printf("NOTE: mbw and llcocc come from /tmp/intp-hw-data (helper must be running)\n\n")
}

####
#	Process tracking
####

global runtime_procfs = 0
global initial_time = 0, runtime = 0
global started = 0, exited = 0
global exitcounter = 0

global mpids
global nprocs = 0

%( @1 == "@system" %?
	/* System-wide mode: no per-process attach. mpids[] stays empty;
	 * nprocs is seeded to 1 in `probe begin` so all metric gates open. */
%:
probe process(@1).begin, process(@1).thread.begin {
	if (initial_time == 0) {
		initial_time = gettimeofday_ns();
	}

	_pid = pid()

	if (tid() > 0 && tid() != pid()) {
		_pid = tid()
	}

	if(!([_pid] in mpids)) {
		printf(" Begin Create monitoring process: (%4d) %s %s\n", _pid, execname(), cmdline_str())
		mpids[_pid] = 0
		nprocs++
		started = 1
		exitcounter = 0
		exited = 0
	}
}

probe process(@1).end, process(@1).thread.end {
	_pid = pid()
	if (tid() > 0 && tid() != pid()) {
		_pid = tid()
	}

	if([_pid] in mpids) {
		printf(" End monitoring process: (%4d) %s\n", _pid, execname())
		delete mpids[_pid]

		if (nprocs > 0) {
			nprocs--
		}

		if (nprocs <= 0) {
			nprocs = 0
			exited = 1
			exitcounter = 0
		}
	}
}
%)

####
#	Block IO call statistics
####

global block_op_dep
global block_tput, block_cput

global block_srv_time

# Issue→complete service-time tracking. Match V3 (eBPF) semantics: take
# both timestamps from the same clock (local_clock_ns) inside the probe
# and store the issue ts in an associative array keyed by request pointer.
# Earlier revision used `$rq->io_start_time_ns` (set by the kernel via
# ktime_get_ns) and diffed against local_clock_ns/sched_clock — those are
# different clock domains across CPUs on multi-socket hosts, so on a 48-
# thread Sapphire Rapids box the `delta > 0 && delta < 10s` sanity gate
# rejected ~all events and blk read 0% always. See METRICS-ALIGNMENT.md.
# %[N] caps the array to bound memory under heavy I/O.
global rq_issue_ns%[16384]

probe kernel.trace("block_rq_issue")?, kernel.trace("block:block_rq_issue")? {
	rq_issue_ns[$rq] = local_clock_ns()
}

probe kernel.trace("block_rq_complete")?, kernel.trace("block:block_rq_complete")? {
	data_len = $rq->__data_len
	block_tput <<< data_len
	block_cput <<< data_len

	if (data_len > 0) {
		if ($rq in rq_issue_ns) {
			delta = local_clock_ns() - rq_issue_ns[$rq]
			delete rq_issue_ns[$rq]
			if (delta > 0 && delta < 10000000000) {
				block_srv_time <<< delta
			}
		}
		block_op_dep += 1
	}
}

function print_block_report()
{
    /* Aligned with V3 (eBPF) blk: physical disk-busy fraction =
     *   util = sum(svctm_ns) / interval_ns * 100
     * V0 / V0.1 / V1 keep their original (over-amplified) formula for
     * backward fidelity; V1.1 deliberately drops it because V1.1's role
     * is to be comparable to V2 / V3 / V3.1, not byte-for-byte with V0.
     * See METRICS-ALIGNMENT.md. */
    if (runtime_procfs <= 0) {
		delete block_op_dep
		delete block_srv_time
		return 0
	}

    if (@count(block_srv_time)) {svctm_sum = @sum(block_srv_time)} else {svctm_sum = 0}

    /* svctm_sum is ns, runtime_procfs is seconds.
     *   util = svctm_sum_ns * 100 / (runtime_procfs * 1e9)
     *        = svctm_sum / (runtime_procfs * 1e7)
     * Divide first to avoid 64-bit overflow on long captures. */
    util = (svctm_sum / 10000000) / runtime_procfs

    if (util < 0) { util = 0 }
    if (util >= 100) { util = 99 }

	delete block_op_dep
	delete block_srv_time
	return util
}

####
#	Network statistics
####

global net_tput
global flows

probe netfilter.ip.local_out {
%( @1 == "@system" %?
	if (length > 0) {
		net_tput <<< length
	}
%:
	if(([pid()] in mpids) && length > 0) {
		net_tput <<< length
		if(!([saddr,daddr,dport] in flows))
			flows[saddr,daddr,dport] = pid()
	}
%)
}

probe netfilter.ip.local_in {
%( @1 == "@system" %?
	if (length > 0) {
		net_tput <<< length
	}
%:
	if(([daddr,saddr,sport] in flows) && length > 0) {
		net_tput <<< length
	}
%)
}

/*
 * nets via NET_TX (vec=2) / NET_RX (vec=3) softirq service-time tracepoints.
 *
 * V0/V0.1 used per-packet kprobes (__dev_queue_xmit + __napi_schedule_irqoff
 * → napi_complete_done). On modern kernels with veth / backlog NAPI those
 * probes degenerate:
 *   - __dev_queue_xmit on veth captures only the trivial driver xmit time;
 *     the queue+protocol time the V0 probe pair captured on physical NICs
 *     in 2014 is now split across other functions.
 *   - napi_complete_done rarely fires for backlog NAPI under sustained
 *     traffic because the queue never empties.
 * Verified empirically on Hetzner kernel 6.8 + veth: per-packet pair gives
 * sub-1% nets at 880 Mbps line rate — truncated to 0 in the IntP int schema.
 *
 * Softirq tracepoints fire for every NET_TX/NET_RX dispatch regardless of
 * device class (physical NIC, lo, veth) and capture actual CPU time spent
 * in the network bottom half — same signal V2's procfs softirq backend and
 * V3.1's bpftrace softirq tracepoint script use. See METRICS-ALIGNMENT.md.
 *
 * V0/V0.1/V1 keep their original per-packet probes for paper-fidelity;
 * V1.1 (modern stap variant) explicitly diverges from V0 here, just as it
 * does for blk.
 */

global net_sent_req
global net_sent_lat
global tx_softirq_start_t

global net_rcv_req
global net_rcv_lat
global rx_softirq_start_t

/* Use the stap softirq tapset (softirq.entry / softirq.exit) — exposes
 * vec_nr as a built-in variable. The raw kernel.trace("irq:softirq_entry")
 * form is unreliable across kernels because $vec accessor visibility
 * depends on the trace event format file having that field exposed. */

/* nets via softirq tracepoints — measures SYSTEM-WIDE NET_TX/NET_RX softirq
 * service time. Intentionally NOT gated by `nprocs > 0` because softirqs
 * are kernel-wide events (no per-process attribution); the metric represents
 * total network stack utilization on the host, aligned with V2's procfs
 * softirq backend and V3.1's bpftrace softirq tracepoint script.
 *
 * Diagnostic counters: increment on every probe fire so we can detect at
 * shutdown whether the softirq tapset is actually attaching (some stap
 * versions silently fail expansion). Printed in the END probe.
 */
global softirq_entry_fires = 0
global softirq_exit_fires = 0
global softirq_tx_seen = 0
global softirq_rx_seen = 0

probe softirq.entry
{
	softirq_entry_fires += 1
	if (vec_nr == 2) {
		softirq_tx_seen += 1
		tx_softirq_start_t[tid()] = gettimeofday_ns();
	} else if (vec_nr == 3) {
		softirq_rx_seen += 1
		rx_softirq_start_t[tid()] = gettimeofday_ns();
	}
}

probe softirq.exit
{
	softirq_exit_fires += 1
	if (vec_nr == 2) {
		st = tx_softirq_start_t[tid()]
		if (st) {
			net_sent_lat <<< gettimeofday_ns() - st
			net_sent_req += 1
			delete tx_softirq_start_t[tid()]
		}
	} else if (vec_nr == 3) {
		st = rx_softirq_start_t[tid()]
		if (st) {
			net_rcv_lat <<< gettimeofday_ns() - st
			net_rcv_req += 1
			delete rx_softirq_start_t[tid()]
		}
	}
}

function print_netstack_report()
{
	if(@count(net_sent_lat)) {_net_sent_lat = @avg(net_sent_lat)} else { _net_sent_lat = 0}
	if(@count(net_rcv_lat)) {_net_rcv_lat = @avg(net_rcv_lat)} else { _net_rcv_lat = 0}

    rcv_util = (_net_rcv_lat * net_rcv_req)/1000/1000/1000
    rcv_util_abs = ((_net_rcv_lat * net_rcv_req)/1000/1000/1000)%1000
    sent_util = (_net_sent_lat * net_sent_req)/1000/1000/1000
    sent_util_abs = ((_net_sent_lat * net_sent_req)/1000/1000/1000)%1000
    util = rcv_util + sent_util + ((rcv_util_abs+sent_util_abs)/100)
    util_abs = ((rcv_util_abs+sent_util_abs)%100)

    if(util > 100) {util = 100;	util_abs = 0}
	if(util_abs >= 100) {util_abs=util_abs/10}

	if(util>=100){
		util=99
	}

	delete net_sent_lat
	delete net_sent_req
	delete net_rcv_lat
	delete net_rcv_req
	return util
}

function print_netphy_report()
{
	tput_eq = @sum(net_tput)/runtime_procfs
	util = (tput_eq*10000/nic_bytes_per_sec)/100

	if(util>=100){
		util=99
	}

	delete net_tput
	return util
}

####
#	CPU statistics
####

global cpu_sched_in_ns, cpu_run_ns
global cpu_sched_in_update
# Initialised at module load by `probe begin` via intp_num_online_cpus().
global CPU_TOTAL_CORES = 1

probe scheduler.ctxswitch
{
	if (nprocs > 0) {
		now = gettimeofday_ns()

		if ([prev_pid] in cpu_sched_in_ns) {
			st = cpu_sched_in_ns[prev_pid]
			if (st > 0 && now > st) {
				cpu_run_ns[prev_pid] += now - st
			}
			delete cpu_sched_in_ns[prev_pid]
		}

%( @1 == "@system" %?
		/* Host-wide CPU accounting: every task entering the CPU is
		 * counted, normalised against CPU_TOTAL_CORES * window_ns
		 * by print_cpu_report (same denominator as per-process mode). */
		cpu_sched_in_ns[next_pid] = now
%:
		if ([next_pid] in mpids) {
			cpu_sched_in_ns[next_pid] = now
		}
%)
	}
}

function print_cpu_report()
{
	if (runtime_procfs <= 0) {
		delete cpu_run_ns
		return 0
	}

	window_ns = runtime_procfs * 1000000000
	run_ns = 0
	now = gettimeofday_ns()

	foreach ([p] in cpu_run_ns)
		run_ns += cpu_run_ns[p]

	foreach ([p] in cpu_sched_in_ns) {
		st = cpu_sched_in_ns[p]
		if (st > 0 && now > st) {
			run_ns += now - st
			cpu_sched_in_update[p] = now
		}
	}

	foreach ([p] in cpu_sched_in_update) {
		cpu_sched_in_ns[p] = cpu_sched_in_update[p]
	}
	delete cpu_sched_in_update

	delete cpu_run_ns

	cap_ns = window_ns * CPU_TOTAL_CORES
	if (cap_ns <= 0) {
		return 0
	}

	util = (run_ns * 100) / cap_ns
	if (util < 0) { util = 0 }
	if (util >= 100) { util = 99 }
	return util
}

####
#	LLC miss ratio (stap-native, faithful to V0)
####

global llc_load, llc_load_misses
global llc_load_t = 0, llc_load_misses_t = 0

%( @1 == "@system" %?
/* System-wide LLC monitoring: perf events attach on every CPU without a
 * .process() filter, so misses on any task (including Spark Driver
 * launched after stap attach or inside a netns) accumulate. */
probe perf.type(3).config(0x000002) { llc_load <<< 1; llc_load_t += 1 }
probe perf.type(3).config(0x010002) { llc_load_misses <<< 1; llc_load_misses_t += 1 }
%:
probe perf.type(3).config(0x000002).process(@1) { llc_load <<< 1; llc_load_t += 1 }
probe perf.type(3).config(0x010002).process(@1) { llc_load_misses <<< 1; llc_load_misses_t += 1 }
%)

function print_cache_report()
{
	if (@count(llc_load))         { _llc_load = @sum(llc_load) }                 else { _llc_load = 0 }
	if (@count(llc_load_misses))  { _llc_load_misses = @sum(llc_load_misses) }   else { _llc_load_misses = 0 }

	llc_miss_ratio = 0
	if (_llc_load > 0) {
		llc_miss_ratio = ((_llc_load_misses * 10000) / _llc_load) / 100
	}

	if (llc_miss_ratio >= 100) {
		llc_miss_ratio = 99
	}

	delete llc_load
	delete llc_load_misses
	llc_load_t = 0
	llc_load_misses_t = 0

	return llc_miss_ratio
}

####
#	Helper-fed hardware metrics (mbw, llcocc)
#
#	The helper writes /tmp/intp-hw-data once per second:
#	    <timestamp_ns>\t<mbw_pct>\t<llcocc_pct>\n
#
#	These embedded C readers run only from the procfs read probe
#	(via print_mem_report / print_llc_report below). procfs read
#	probes execute in user-task context, so filp_open / kernel_read
#	are safe here.
####

%{
#include <linux/fs.h>
#include <linux/slab.h>

/* Reads /tmp/intp-hw-data and returns the requested field
 * (1 = mbw, 2 = llcocc). Returns 0 on any error or if helper is not
 * running (file missing). */
static long intp_read_hw_field(int field) {
    struct file *file;
    char buf[96];
    loff_t pos = 0;
    ssize_t ret;
    long values[3] = {0, 0, 0};
    int idx = 0, i;
    long acc = 0;
    int saw_digit = 0;

    file = filp_open("/tmp/intp-hw-data", O_RDONLY, 0);
    if (IS_ERR(file)) return 0;

    ret = kernel_read(file, buf, sizeof(buf) - 1, &pos);
    filp_close(file, NULL);
    if (ret <= 0) return 0;
    buf[ret] = '\0';

    for (i = 0; i < ret && idx < 3; i++) {
        char c = buf[i];
        if (c >= '0' && c <= '9') {
            acc = acc * 10 + (c - '0');
            saw_digit = 1;
        } else if (saw_digit) {
            values[idx++] = acc;
            acc = 0;
            saw_digit = 0;
        }
    }
    if (saw_digit && idx < 3) values[idx++] = acc;

    if (field == 1) return values[1];
    if (field == 2) return values[2];
    return 0;
}
%}

function read_hw_mbw:long()    %{ STAP_RETVALUE = intp_read_hw_field(1); %}
function read_hw_llcocc:long() %{ STAP_RETVALUE = intp_read_hw_field(2); %}

function print_mem_report()
{
	return read_hw_mbw()
}

function print_llc_report()
{
	return read_hw_llcocc()
}

####
#	procfs output
####

probe procfs("intestbench").read
{
	if(runtime_procfs > 0) {

		netphy_util = print_netphy_report()
		block_util = print_block_report()
		netstak_util = print_netstack_report()
		mem_util = print_mem_report()
		cpu_util = print_cpu_report()
		cache_ratio = print_cache_report()
		cache_occ = print_llc_report()

		buff = sprintf("time_ms\tnetp\tnets\tblk\tmbw\tllcmr\tllcocc\tcpu\n%d\t%02d\t%02d\t%02d\t%02d\t%02d\t%02d\t%02d\n",
						(gettimeofday_ns() - initial_time) / 1000000,
						netphy_util,
						netstak_util,
						block_util,
						mem_util,
						cache_ratio,
						cache_occ,
						cpu_util);

		runtime_procfs = 0

		$value = buff
	}
}

probe timer.s(1) {

	if(exited == 0) {
		runtime = gettimeofday_ns() - initial_time
		runtime_procfs = runtime_procfs + interval
	}

	if(exited == 1) {
		exitcounter++
		printf("Waiting %d seconds to exit \n", exitcounter);

		if(exitcounter == 30) {
			exit()
		}
	}
}

probe end
{
	printf("\n\nruntime: %d ns\n", runtime)
	printf("\nExiting IntP on %s\n", ctime(gettimeofday_s()))
}
