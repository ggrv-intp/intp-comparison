# IntP testbed capability snapshot — companion to the SBAC-PAD 2026 paper.
#
# This file is the canonical capability fingerprint of the campaign host
# (intp-master / Hetzner Sapphire Rapids dedicated). It is produced by
# `shared/intp-detect.sh`, called once at the start of every campaign run
# by `run-big-batch.sh`, and re-emitted alongside every result snapshot
# so each rep records the exact hardware/software profile under which it
# was measured.
#
# Values below correspond to the campaign reported in the paper. The
# per-snapshot copy lives next to each result tree as `capabilities.env`;
# this root-level `capabilities-sbacpad.env` is the stable, paper-cited copy.
#
# To regenerate on another host:
#   shared/intp-detect.sh > capabilities-sbacpad.env

INTP_NIC_IFACE=eno1
INTP_NIC_SPEED_MBPS=1000
INTP_LLC_SIZE_KB=46080
INTP_LLC_LEVEL=3
INTP_RDT_CQM=1
INTP_RDT_CQM_OCCUP=1
INTP_RDT_CQM_MBM=1
INTP_RDT_CAT_L3=1
INTP_RDT_MBA=1
INTP_RESCTRL_AVAILABLE=1
INTP_RESCTRL_MOUNTED=1
INTP_CPU_VENDOR=GenuineIntel
INTP_CPU_MODEL="IntelR XeonR Gold 5412U"
INTP_SOCKET_COUNT=1
INTP_CPU_COUNT=48
INTP_MEM_BW_MBPS=281600
INTP_BTF_AVAILABLE=1
