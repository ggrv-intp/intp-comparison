# IntP testbed capability snapshot — companion to the SBAC-PAD 2026 paper.
#
# Verbatim `shared/intp-detect.sh` output captured on the campaign host
# (Intel Xeon Gold 5412U, Sapphire Rapids; dual-boot Ubuntu 22.04/kernel 5.15
# and Ubuntu 24.04/kernel 6.8 — the hardware fingerprint is identical on both
# legs). Detected 2026-05-15T21:12:37+00:00 during the v0.2 campaign leg.
#
# intp-detect.sh runs once at the start of every campaign via run-big-batch.sh
# and re-emits a per-snapshot `capabilities.env` next to each result tree;
# this root-level `capabilities-sbacpad.env` is the stable, paper-cited copy.
#
# To regenerate on another host:
#   shared/intp-detect.sh > capabilities-sbacpad.env

INTP_NIC_IFACE=eno1
INTP_DEFAULT_NIC_IFACE=eno1
INTP_NIC_SPEED_MBPS=1000
INTP_LLC_SIZE_KB=46080
INTP_LLC_LEVEL=3
INTP_RDT_CQM=1
INTP_RDT_CQM_OCCUP=1
INTP_RDT_CQM_MBM=1
INTP_RDT_CAT_L3=1
INTP_RDT_MBA=1
INTP_RESCTRL_AVAILABLE=1
INTP_RESCTRL_MOUNTED=1
INTP_CPU_VENDOR=GenuineIntel
INTP_CPU_MODEL="IntelR XeonR Gold 5412U"
INTP_SOCKET_COUNT=1
INTP_CPU_COUNT=48
INTP_MEM_BW_MBPS=281600
INTP_BTF_AVAILABLE=1
INTP_IMC_PMU_TYPE=73
INTP_IMC_PMU_TYPE_FIRST=73
INTP_IMC_PMU_TYPE_LAST=80
INTP_IMC_CHANNEL_COUNT=8
INTP_CMT_SCALE_FACTOR=49152
INTP_CMT_SCALE_FACTOR_FALLBACK=1
INTP_DEFAULT_BLOCK_DEV=nvme0n1
