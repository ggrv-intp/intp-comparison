    given-names: "André"
    affiliation: "PPGCC/PUCRS"
    orcid: "https://orcid.org/0000-0002-1639-3238"
repository-code: "https://github.com/ggrv-intp/intp"
license: MIT
type: software
keywords:
  - interference profiling
  - Linux kernel
  - SystemTap
  - eBPF
  - bpftrace
  - performance monitoring
  - cloud computing
version: "1.0.0"
date-released: "2026-04-20"
