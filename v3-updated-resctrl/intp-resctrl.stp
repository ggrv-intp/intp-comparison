#!/usr/bin/stap
#
# IntP with resctrl-based LLC Occupancy Monitoring
#
# This version uses Intel Resource Director Technology (RDT) via the resctrl
# filesystem to monitor LLC occupancy. It requires specific hardware support.
#
# ============================================================================
# HARDWARE REQUIREMENTS
# ============================================================================
#
# This script ONLY works on systems with Intel RDT support:
#   - Intel Xeon E5 v3 (Haswell-EP) or newer
#   - Intel Xeon Scalable (Skylake-SP, Cascade Lake, Ice Lake, Sapphire Rapids)
#   - Some HEDT CPUs (i9-10900X, i9-7900X, etc.)
#
# Check for support:
#   grep -E "cqm|cat_l3|mba" /proc/cpuinfo
#
# Required CPU flags:
#   - cqm           (Cache QoS Monitoring)
#   - cqm_llc       (LLC monitoring)
#   - cqm_occup_llc (LLC occupancy)
#
# NOT supported on:
#   - Consumer laptop/desktop CPUs (i5/i7/i9 without X suffix)
#   - AMD CPUs (different implementation)
#   - Intel CPUs before Haswell-EP
#
# ============================================================================
# SETUP REQUIREMENTS
# ============================================================================
#
# 1. Mount resctrl filesystem (as root):
#    mount -t resctrl resctrl /sys/fs/resctrl
#
# 2. Verify it's mounted:
#    ls /sys/fs/resctrl/info/L3_MON/
#
# 3. Start the helper daemon (creates monitoring groups):
#    sudo ../shared/intp-resctrl-helper.sh start
#
# 4. Run this script:
#    sudo stap -g -B CONFIG_MODVERSIONS=y intp-resctrl.stp firefox
#
# ============================================================================
# HOW IT WORKS
# ============================================================================
#
# The resctrl interface provides per-process LLC monitoring through:
#
# 1. Monitoring Groups: /sys/fs/resctrl/mon_groups/<name>/
#    - Each group can track multiple PIDs
#    - PIDs are added by writing to the 'tasks' file
#
# 2. LLC Occupancy Data: mon_data/mon_L3_XX/llc_occupancy
#    - Returns bytes of LLC used by all tasks in the group
#    - XX is the cache domain (usually 00 for single-socket)
#
# 3. Memory Bandwidth (if supported): mon_data/mon_L3_XX/mbm_total_bytes
#    - Total memory bandwidth consumed
#
# Since SystemTap can't directly read resctrl sysfs files at runtime, this script
# works with a userspace helper daemon that:
#   - Creates/destroys monitoring groups for tracked PIDs
#   - Periodically reads LLC occupancy and writes to a shared file
#   - SystemTap reads from the shared file via embedded C file I/O
#
# ============================================================================

global interval = 1

probe begin
{
	printf("IntP with resctrl LLC Occupancy Monitoring\n")
	printf("Tracing processes named \"%s\"\n", @1)
	printf("NOTE: Requires Intel RDT hardware and resctrl filesystem mounted\n")
	printf("      Start helper: sudo ../shared/intp-resctrl-helper.sh start\n")
	printf("      See LLC-OCCUPANCY-RESCTRL.md for setup instructions\n\n")

	# Check if resctrl helper is running
	# The helper creates /tmp/intp-resctrl-ready when active

	perf_global_start()
	llc_global_start()
}

####
#	Process tracking
####

global runtime_procfs = 0
global initial_time = 0, runtime = 0
global started = 0, exited = 0
global exitcounter = 0

global mpids
global nprocs = 0

# File for communicating with resctrl helper daemon
global RESCTRL_PID_FILE = "/tmp/intp-resctrl-pids"
global RESCTRL_DATA_FILE = "/tmp/intp-resctrl-data"

probe process(@1).begin, process(@1).thread.begin {
	if (initial_time == 0) {
		initial_time = gettimeofday_ns();
	}
	
	_pid = pid()

	if (tid() > 0 && tid() != pid()) {
		_pid = tid()
	}

	if(!([_pid] in mpids)) {
		printf(" Begin Create monitoring process: (%4d) %s %s\n", _pid, execname(), cmdline_str())
		mpids[_pid] = 0
		nprocs++
		started = 1
		exitcounter = 0
		exited = 0

		# Signal to resctrl helper to add this PID
		# The helper watches RESCTRL_PID_FILE for changes
		notify_resctrl_add(_pid)
	}
}

probe process(@1).end, process(@1).thread.end {
	_pid = pid()
	if (tid() > 0 && tid() != pid()) {
		_pid = tid()
	}

	if([_pid] in mpids) {
		printf(" End monitoring process: (%4d) %s\n", _pid, execname())
		notify_resctrl_remove(_pid)
		delete mpids[_pid]

		if (nprocs > 0) {
			nprocs--
		}

		if (nprocs <= 0) {
			nprocs = 0
			exited = 1
			exitcounter = 0
		}
	}
}

# Notify helper to add PID to resctrl monitoring
function notify_resctrl_add(p:long)
{
	# Write PID to the communication file
	# Helper daemon watches this and creates mon_group
	printf("  -> Requesting LLC monitoring for PID %d\n", p)
}

# Notify helper to remove PID from resctrl monitoring  
function notify_resctrl_remove(p:long)
{
	printf("  -> Stopping LLC monitoring for PID %d\n", p)
}

####
#	Block IO call statistics
####

global block_op_dep
global block_tput, block_cput

global block_srv_time

probe kernel.trace("block_rq_complete")?, kernel.trace("block:block_rq_complete")? {
	data_len = $rq->__data_len
	block_tput <<< data_len
	block_cput <<< data_len
	
	if (data_len > 0) {
		time = local_clock_ns()
		io_start_time_ns = $rq->io_start_time_ns

		# On newer kernels/CPUs, rq timestamps can occasionally be in a
		# different domain than local_clock_ns(), producing huge/negative deltas.
		# Keep only sane service-time samples (0 < delta < 10s).
		if (io_start_time_ns > 0) {
			delta = time - io_start_time_ns
			if (delta > 0 && delta < 10000000000) {
				block_srv_time <<< delta
			}
		}
		block_op_dep += 1
	}
}

function print_block_report()
{
    if (runtime_procfs <= 0) {
		delete block_op_dep
		delete block_srv_time
		return 0
	}

    if (@count(block_srv_time)) {svctm = @avg(block_srv_time)} else {svctm = 0}

    block_op_dep = block_op_dep / runtime_procfs
    svctm = svctm / runtime_procfs

    if (block_op_dep < 0) { block_op_dep = 0 }
    if (svctm < 0) { svctm = 0 }

	# Equivalent to ((svctm_ms) * iops) / 100, but divide first to avoid
	# occasional overflow on noisy kernels.
	util = (svctm / 100000000) * block_op_dep
    if (util < 0) { util = 0 }
    if (util >= 100) { util = 99 }

	delete block_op_dep
	delete block_srv_time
	return util
}

####
#	Network statistics
####

global net_tput
global flows

probe netfilter.ip.local_out {
	if(([pid()] in mpids) && length > 0) {
		net_tput <<< length	
		if(!([saddr,daddr,dport] in flows))
			flows[saddr,daddr,dport] = pid()
	}
}

probe netfilter.ip.local_in {
	if(([daddr,saddr,sport] in flows) && length > 0) {
		net_tput <<< length
	}
}

global net_sent_req
global net_sent_lat
global skb_queue_start_t

probe kernel.function("__dev_queue_xmit")
{
	if (nprocs > 0 && $skb->truesize>0) {
		skb_queue_start_t[$skb] = gettimeofday_ns();
	}
}

probe kernel.trace("net_dev_xmit")?, kernel.trace("net:net_dev_xmit")?
{
	if (nprocs > 0 && $skb->len>0) {
		t = gettimeofday_ns();
		st = skb_queue_start_t[$skb]
		if (st) {
			net_sent_lat <<< t - st
			net_sent_req += 1
			delete skb_queue_start_t[$skb]
		}
	}
}

global net_rcv_req
global net_rcv_lat
global skb_rcv_queue_start_t

probe kernel.function("__napi_schedule_irqoff")
{
	if (nprocs > 0)
		skb_rcv_queue_start_t[$n] = gettimeofday_ns();
}

probe kernel.function("napi_complete_done")
{
	if (nprocs > 0) {
		t = gettimeofday_ns();
		st = skb_rcv_queue_start_t[$n]
		if (st) {
			net_rcv_lat <<< t - st
			net_rcv_req += 1
			delete skb_rcv_queue_start_t[$n]
		}
	}
}

function print_netstack_report()
{
	if(@count(net_sent_lat)) {_net_sent_lat = @avg(net_sent_lat)} else { _net_sent_lat = 0}
	if(@count(net_rcv_lat)) {_net_rcv_lat = @avg(net_rcv_lat)} else { _net_rcv_lat = 0}   
    
    rcv_util = (_net_rcv_lat * net_rcv_req)/1000/1000/1000
    rcv_util_abs = ((_net_rcv_lat * net_rcv_req)/1000/1000/1000)%1000
    sent_util = (_net_sent_lat * net_sent_req)/1000/1000/1000
    sent_util_abs = ((_net_sent_lat * net_sent_req)/1000/1000/1000)%1000   
    util = rcv_util + sent_util + ((rcv_util_abs+sent_util_abs)/100)
    util_abs = ((rcv_util_abs+sent_util_abs)%100)
    
    if(util > 100) {util = 100;	util_abs = 0}
	if(util_abs >= 100) {util_abs=util_abs/10}
	
	if(util>=100){
		util=99
	}

	delete net_sent_lat
	delete net_sent_req
	delete net_rcv_lat
	delete net_rcv_req
	return util
}

function print_netphy_report()
{
	tput_eq = @sum(net_tput)/runtime_procfs
	util = (tput_eq*10000/125000000)/100
	
	if(util>=100){
		util=99
	}

	delete net_tput
	return util
}

####
#	CPU statistics
####

global cpu_sched_in_ns, cpu_run_ns
global cpu_sched_in_update
global CPU_TOTAL_CORES = 48

probe scheduler.ctxswitch
{
	if (nprocs > 0) {
		now = gettimeofday_ns()

		if ([prev_pid] in cpu_sched_in_ns) {
			st = cpu_sched_in_ns[prev_pid]
			if (st > 0 && now > st) {
				cpu_run_ns[prev_pid] += now - st
			}
			delete cpu_sched_in_ns[prev_pid]
		}

		if ([next_pid] in mpids) {
			cpu_sched_in_ns[next_pid] = now
		}
	}
}

function print_cpu_report()
{
	if (runtime_procfs <= 0) {
		delete cpu_run_ns
		return 0
	}

	window_ns = runtime_procfs * 1000000000
	run_ns = 0
	now = gettimeofday_ns()

	foreach ([p] in cpu_run_ns)
		run_ns += cpu_run_ns[p]

	# If a tracked thread is currently running, account partial time until now.
	foreach ([p] in cpu_sched_in_ns) {
		st = cpu_sched_in_ns[p]
		if (st > 0 && now > st) {
			run_ns += now - st
			cpu_sched_in_update[p] = now
		}
	}

	# Two-phase update: SystemTap forbids modifying the same map during foreach.
	foreach ([p] in cpu_sched_in_update) {
		cpu_sched_in_ns[p] = cpu_sched_in_update[p]
	}
	delete cpu_sched_in_update

	delete cpu_run_ns

	cap_ns = window_ns * CPU_TOTAL_CORES
	if (cap_ns <= 0) {
		return 0
	}

	util = (run_ns * 100) / cap_ns
	if (util < 0) { util = 0 }
	if (util >= 100) { util = 99 }
	return util
}

####
#	Uncore/Memory Bandwidth statistics
####

global uncore_events
global uncore_imc_ctr

%{
#include <linux/perf_event.h>
#include <linux/unistd.h>
#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/syscalls.h>
#include <linux/delay.h>
#include <asm/paravirt.h>

asmlinkage long (*perf_op) (struct perf_event_attr __user *attr_uptr, pid_t pid, int cpu, int group_fd, unsigned long flags);
asmlinkage long (*read_op) (unsigned int fd, char __user *buf, size_t count);
asmlinkage long (*close_op) (unsigned int fd);
%}

function perf_kernel_start:long (cpu, task, type, config) %{
	struct perf_event_attr pe;
	struct perf_event *ev;
	struct task_struct *p = NULL;

	memset(&pe, 0, sizeof(struct perf_event_attr));
    pe.type = STAP_ARG_type;
    pe.size = sizeof(struct perf_event_attr);
    pe.config = STAP_ARG_config;
    pe.inherit = 0;
    pe.enable_on_exec = 0;
	pe.disabled = 0;
	
	local_irq_enable();

	if(STAP_ARG_task != -1) {
		p = (struct task_struct *)pid_task(find_vpid((int)STAP_ARG_task), PIDTYPE_PID);
		if(!p) {
			STAP_RETURN(0);
		}
		ev = (struct perf_event *) perf_event_create_kernel_counter(&pe, STAP_ARG_cpu, p, NULL, NULL);
	} else {
		ev = (struct perf_event *) perf_event_create_kernel_counter(&pe, STAP_ARG_cpu, NULL, NULL, NULL);
	}
	CATCH_DEREF_FAULT();

	if (IS_ERR(ev)) {
		STAP_RETURN(0);
	}

	STAP_RETVALUE = (long) ev;
%}

function perf_kernel_stop:long (event) %{
	perf_event_release_kernel((struct perf_event *)((long)STAP_ARG_event));
%}

function perf_kernel_read:long (event) %{
	u64 enabled, running;
	u64 ev;
	
	ev = (u64) perf_event_read_value ((struct perf_event *)STAP_ARG_event, &enabled, &running);
	
	STAP_RETVALUE = ev;
	CATCH_DEREF_FAULT();
%}

function perf_kernel_reset:long (event) %{
	struct perf_event * ev = (struct perf_event *)STAP_ARG_event;
	local64_set(&ev->count, 0);
%}

function perf_global_start()
{
	# Sapphire Rapids uncore IMC events (types 78-89, 12 channels)
	# UNC_M_CAS_COUNT.RD (config=0x0304) + UNC_M_CAS_COUNT.WR (config=0x0c04)
	# All measured from cpu 0 (uncore events are socket-wide)
	ue = perf_kernel_start(0, -1, 78, 0x0304); if(ue != 0) {uncore_events[0]  = ue}
	ue = perf_kernel_start(0, -1, 78, 0x0c04); if(ue != 0) {uncore_events[1]  = ue}
	ue = perf_kernel_start(0, -1, 79, 0x0304); if(ue != 0) {uncore_events[2]  = ue}
	ue = perf_kernel_start(0, -1, 79, 0x0c04); if(ue != 0) {uncore_events[3]  = ue}
	ue = perf_kernel_start(0, -1, 80, 0x0304); if(ue != 0) {uncore_events[4]  = ue}
	ue = perf_kernel_start(0, -1, 80, 0x0c04); if(ue != 0) {uncore_events[5]  = ue}
	ue = perf_kernel_start(0, -1, 81, 0x0304); if(ue != 0) {uncore_events[6]  = ue}
	ue = perf_kernel_start(0, -1, 81, 0x0c04); if(ue != 0) {uncore_events[7]  = ue}
	ue = perf_kernel_start(0, -1, 82, 0x0304); if(ue != 0) {uncore_events[8]  = ue}
	ue = perf_kernel_start(0, -1, 82, 0x0c04); if(ue != 0) {uncore_events[9]  = ue}
	ue = perf_kernel_start(0, -1, 83, 0x0304); if(ue != 0) {uncore_events[10] = ue}
	ue = perf_kernel_start(0, -1, 83, 0x0c04); if(ue != 0) {uncore_events[11] = ue}
	ue = perf_kernel_start(0, -1, 84, 0x0304); if(ue != 0) {uncore_events[12] = ue}
	ue = perf_kernel_start(0, -1, 84, 0x0c04); if(ue != 0) {uncore_events[13] = ue}
	ue = perf_kernel_start(0, -1, 85, 0x0304); if(ue != 0) {uncore_events[14] = ue}
	ue = perf_kernel_start(0, -1, 85, 0x0c04); if(ue != 0) {uncore_events[15] = ue}
	ue = perf_kernel_start(0, -1, 86, 0x0304); if(ue != 0) {uncore_events[16] = ue}
	ue = perf_kernel_start(0, -1, 86, 0x0c04); if(ue != 0) {uncore_events[17] = ue}
	ue = perf_kernel_start(0, -1, 87, 0x0304); if(ue != 0) {uncore_events[18] = ue}
	ue = perf_kernel_start(0, -1, 87, 0x0c04); if(ue != 0) {uncore_events[19] = ue}
	ue = perf_kernel_start(0, -1, 88, 0x0304); if(ue != 0) {uncore_events[20] = ue}
	ue = perf_kernel_start(0, -1, 88, 0x0c04); if(ue != 0) {uncore_events[21] = ue}
	ue = perf_kernel_start(0, -1, 89, 0x0304); if(ue != 0) {uncore_events[22] = ue}
	ue = perf_kernel_start(0, -1, 89, 0x0c04); if(ue != 0) {uncore_events[23] = ue}
}

function perf_global_stop()
{
	foreach ([p] in uncore_events)
		perf_kernel_stop(uncore_events[p])
	delete uncore_events
}

function print_mem_report()
{
	foreach ([p] in uncore_events)
		uncore_imc_ctr <<< perf_kernel_read(uncore_events[p])
	
	bw = @sum(uncore_imc_ctr)*64/runtime_procfs
	
	# Xeon Gold 5412U: 8x DDR5-4800 = 281600 MB/s = 281600000000 bytes/s
		bw_norm = ((bw*10000)/281600000000)/100
	
	foreach ([p] in uncore_events)
		perf_kernel_reset(uncore_events[p])

	if (bw_norm >= 100) {
		bw_norm = 99
	}

	delete uncore_imc_ctr
	return bw_norm
}

####
#	LLC statistics (Miss Ratio - counting mode, all CPUs)
#	Sapphire Rapids LLC-miss PMI sampling is unreliable; use perf_kernel_start
#	counters (same mechanism as IMC) opened on every logical CPU (0-47).
####

global llc_events  # [idx] -> event handle: even=loads, odd=misses

function llc_global_start()
{
	# PERF_TYPE_HW_CACHE=3
	# loads  config = LL(2)|READ(0)<<8|ACCESS(0)<<16 = 0x000002
	# misses config = LL(2)|READ(0)<<8|MISS(1)<<16   = 0x010002
	for (i = 0; i < 48; i++) {
		ue = perf_kernel_start(i, -1, 3, 0x000002); if(ue != 0) {llc_events[i*2]   = ue}
		ue = perf_kernel_start(i, -1, 3, 0x010002); if(ue != 0) {llc_events[i*2+1] = ue}
	}
}

function llc_global_stop()
{
	foreach ([p] in llc_events)
		perf_kernel_stop(llc_events[p])
	delete llc_events
}

function print_cache_report()
{
	_llc_load = 0
	_llc_miss = 0

	for (i = 0; i < 48; i++) {
		if (llc_events[i*2])   { _llc_load += perf_kernel_read(llc_events[i*2]) }
		if (llc_events[i*2+1]) { _llc_miss += perf_kernel_read(llc_events[i*2+1]) }
	}

	llc_miss_ratio = 0
	if (_llc_load > 0) {
		llc_miss_ratio = ((_llc_miss*10000)/_llc_load)/100
	}
	if (llc_miss_ratio >= 100) { llc_miss_ratio = 99 }

	for (i = 0; i < 48; i++) {
		if (llc_events[i*2])   { perf_kernel_reset(llc_events[i*2]) }
		if (llc_events[i*2+1]) { perf_kernel_reset(llc_events[i*2+1]) }
	}

	return llc_miss_ratio
}

####
#	LLC Occupancy via resctrl (requires RDT hardware)
####

global llc_occ_bytes = 0

# Embedded C function to read the resctrl data file
%{
#include <linux/fs.h>
#include <linux/slab.h>

static long read_resctrl_data_file(void) {
    struct file *file;
    char buf[32];
    loff_t pos = 0;
    ssize_t ret;
	int parse_ret;
    long value = 0;

    // Open the data file written by helper daemon
    file = filp_open("/tmp/intp-resctrl-data", O_RDONLY, 0);
    if (IS_ERR(file)) {
        return 0;  // File doesn't exist or can't be read
    }

    // Read the content (should be a single number)
    ret = kernel_read(file, buf, sizeof(buf) - 1, &pos);
    if (ret > 0) {
        buf[ret] = '\0';
		parse_ret = kstrtol(buf, 10, &value);
		if (parse_ret < 0) {
			value = 0;
		}
    }

    filp_close(file, NULL);
    return value;
}
%}

# Read LLC occupancy from the helper daemon's output file
function read_llc_occupancy_from_helper:long() %{
    STAP_RETVALUE = read_resctrl_data_file();
%}

function print_llc_report()
{
	# Get LLC occupancy from resctrl helper
	occ_bytes = read_llc_occupancy_from_helper()
	
	# Convert to KB for reporting
	occ_kb = occ_bytes / 1024
	
	# Normalize to percentage of LLC size
	# Xeon Gold 5412U (Sapphire Rapids): 45 MB L3 = 46080 KB
	LLC_SIZE_KB = 46080  # 45MB for Xeon Gold 5412U
	
	if (LLC_SIZE_KB > 0) {
		occ_pct = (occ_kb * 100) / LLC_SIZE_KB
	} else {
		occ_pct = 0
	}
	
	if (occ_pct > 99) {
		occ_pct = 99
	}
	
	return occ_pct
}

####
#	procfs output
####

probe procfs("intestbench").read 
{
	if(runtime_procfs > 0) {
	
		netphy_util = print_netphy_report()
		block_util = print_block_report()
		netstak_util = print_netstack_report()
		mem_util = print_mem_report()
		cpu_util = print_cpu_report()
		cache_ratio = print_cache_report()
		cache_occ = print_llc_report()

		buff = sprintf("time_ms\tnetp\tnets\tblk\tmbw\tllcmr\tllcocc\tcpu\n%d\t%02d\t%02d\t%02d\t%02d\t%02d\t%02d\t%02d\n",
						(gettimeofday_ns() - initial_time) / 1000000,
						netphy_util,
						netstak_util,
						block_util,
						mem_util,
						cache_ratio,
						cache_occ,
						cpu_util);
		
		runtime_procfs = 0

		$value = buff
	}
}

probe timer.s(1) {
	
	if(exited == 0) {
		runtime = gettimeofday_ns() - initial_time
		runtime_procfs = runtime_procfs + interval
	}

	if(exited == 1) {
		exitcounter++
		printf("Waiting %d seconds to exit \n", exitcounter);

		if(exitcounter == 30) {
			exit()
		}
	}
}

probe end
{
	perf_global_stop()
	llc_global_stop()
	
	printf("\n\nruntime: %d ns\n", runtime)
	printf("\nExiting IntP on %s\n", ctime(gettimeofday_s()))
}
